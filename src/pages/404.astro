---
// src/pages/404.astro
// 1. GitHub Pages deep-link fix – GitHub Pages serves this for every unmatched URL.
//    The script bounces the user back to the base root with ?p= so index.astro
//    can restore the correct path via history.replaceState.
// 2. Cloudflare Pages / genuine 404 – shows a friendly "page not found" UI.
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Page Not Found – InfraConf Africa</title>
    <meta name="robots" content="noindex" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #0d1117;
        --border: #30363d;
        --accent: #58a6ff;
        --text: #e6edf3;
        --muted: #8b949e;
      }

      html, body { height: 100%; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 2rem;
      }

      .container { text-align: center; max-width: 480px; }

      .code {
        font-size: 7rem;
        font-weight: 800;
        line-height: 1;
        background: linear-gradient(135deg, #58a6ff 0%, #bc8cff 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 1rem;
      }

      h1 { font-size: 1.5rem; font-weight: 600; margin-bottom: 0.75rem; }
      p  { color: var(--muted); line-height: 1.6; margin-bottom: 2rem; }

      .actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

      a {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.6rem 1.25rem;
        border-radius: 0.5rem;
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
        transition: opacity 0.2s;
      }
      a:hover { opacity: 0.8; }

      .btn-primary   { background: var(--accent); color: #0d1117; }
      .btn-secondary { background: transparent; border: 1px solid var(--border); color: var(--text); }

      #redirect-notice { margin-top: 1.5rem; font-size: 0.8rem; color: var(--muted); display: none; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="code">404</div>
      <h1>Page not found</h1>
      <p>The page you're looking for doesn't exist or may have been moved.</p>
      <div class="actions">
        <a href={base} class="btn-primary">← Go home</a>
        <a href={`${base}blog`} class="btn-secondary">Browse blog</a>
      </div>
      <p id="redirect-notice">Redirecting you to the right place…</p>
    </div>

    <!--
      GitHub Pages deep-link fix.
      When GH Pages can't find /infraconf-web/blog it serves this 404.html.
      We strip the base prefix (/infraconf-web) from the pathname to get the
      sub-path (/blog), then redirect to the base root with ?p=/blog so that
      index.astro's restore script can do history.replaceState to /infraconf-web/blog.
    -->
    <script define:vars={{ base }}>
      (function () {
        var loc      = window.location;
        var pathname = loc.pathname;

        // base without trailing slash, e.g. "/infraconf-web" or ""
        var baseRoot = base.replace(/\/$/, '');

        // If we're literally on the /404 page, just show the UI
        if (pathname === baseRoot + '/404' || pathname === baseRoot + '/404/') return;

        // Only redirect when the path starts with our base (i.e. we're on the right site)
        var underBase = baseRoot === ''
          ? (pathname !== '/' && pathname !== '')
          : pathname.startsWith(baseRoot + '/') || pathname === baseRoot;

        if (!underBase) return;

        // Strip base to get the intended sub-path, e.g. /blog
        var subPath = pathname.startsWith(baseRoot)
          ? pathname.slice(baseRoot.length) || '/'
          : pathname;
        if (!subPath.startsWith('/')) subPath = '/' + subPath;

        // Don't redirect for genuinely home-level paths
        if (subPath === '/' || subPath === '') return;

        var notice = document.getElementById('redirect-notice');
        if (notice) notice.style.display = 'block';

        var query = '?p=' + encodeURIComponent(subPath)
          + (loc.search ? '&q=' + encodeURIComponent(loc.search.slice(1)) : '')
          + loc.hash;

        // Go to the base root + query so index.astro can restore the path
        loc.replace(loc.protocol + '//' + loc.host + baseRoot + '/' + query);
      })();
    </script>
  </body>
</html>

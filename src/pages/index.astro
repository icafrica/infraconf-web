---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TracksSection from '../components/TracksSection.astro';
import ProgrammeSection from '../components/ProgrammeSection.astro';
import CfpSection from '../components/CfpSection.astro';
import SponsorSection from '../components/SponsorSection.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

// Fetch 3 most recent blog posts for the homepage
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout title="InfraConf Africa 2026 — Infrastructure Engineering Conference">
  <Nav />

  <!-- Nav spacer -->
  <div style="height: 64px;"></div>

  <Hero />


  <TracksSection />
  <ProgrammeSection />
  <CfpSection />
  <SponsorSection />



  <!-- Blog preview section -->
  {recentPosts.length >= 3 && (
    <section class="section section--cream" aria-labelledby="blog-preview-heading">
      <div class="container">
        <div class="section__header">
          <span class="label">06 — Blog</span>
          <hr>
          <h2 class="label" id="blog-preview-heading" style="color:var(--muted)">From the community</h2>
        </div>

        <div class="blog-grid reveal">
          {recentPosts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              author={post.data.author}
              tags={post.data.tags}
              id={post.id}
            />
          ))}
        </div>

        <div style="margin-top: var(--space-md); text-align:center;">
          <a href={`${base}blog`} class="btn btn--forest">
            View all posts →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA Band -->
  <div class="cta-band" role="complementary" aria-label="Call to action">
    <div class="container">
      <div class="cta-band__inner">
        <h2 class="cta-band__heading">
          Build the layer.<br>
          <em>Attend free.</em>
        </h2>
        <div class="cta-band__actions">
          <a href={`${base}register`} class="btn btn--forest">Apply for a pass</a>
          <a href={`${base}cfp`} class="btn btn--outline-forest">Submit a talk</a>
        </div>
      </div>
    </div>
  </div>

  <Footer />

  {/* GitHub Pages deep-link fix – the 404.astro page redirects to here with ?p=/intended/path */}
  <script define:vars={{ base: base.replace(/\/?$/, '/') }}>
    (function () {
      var search = window.location.search;
      if (!search) return;
      var params = new URLSearchParams(search);
      var p = params.get('p');
      if (!p) return;

      // Build the full intended URL: base + sub-path (strip leading slash from p to avoid double-slash)
      var baseNoTrail = base.replace(/\/$/, '');
      var subPath = p.replace(/^\//, '');
      var targetUrl = window.location.protocol + '//' + window.location.host
        + baseNoTrail + '/' + subPath;

      // Add back query string and hash if present
      var q = params.get('q');
      if (q) targetUrl += '?' + q;
      targetUrl += window.location.hash;

      // Navigate to the actual pre-rendered page (not just a history trick)
      window.location.replace(targetUrl);
    })();
  </script>
</BaseLayout>

<style>
  /* Why grid */
  .why__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }
  .why__grid--bottom {
    border-top: none;
  }

  .why__cell { background: var(--cream); padding: var(--space-lg) var(--space-md); }
  .why__cell--accent { background: var(--forest); color: var(--white); }

  /* Visa rejection callout */
  .visa-callout {
    position: relative;
    overflow: hidden;
    background: #0d1f17;
    border: 1px solid var(--mid);
    border-top: none;
    border-bottom: none;
    padding: var(--space-xl) var(--space-lg);
    display: grid;
    grid-template-columns: 1fr;
  }

  .visa-callout__stamp {
    position: absolute;
    top: 50%;
    right: -20px;
    transform: translateY(-50%) rotate(-12deg);
    font-family: var(--mono);
    font-size: clamp(4rem, 10vw, 9rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(196, 43, 43, 0.07);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }

  .visa-callout__body {
    position: relative;
    z-index: 1;
    max-width: 72ch;
  }

  .visa-callout__label {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(196, 43, 43, 0.7);
    margin-bottom: var(--space-sm);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .visa-callout__label::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    background: rgba(196, 43, 43, 0.4);
  }

  .visa-callout__heading {
    font-family: var(--serif);
    font-size: clamp(1.6rem, 3.5vw, 2.5rem);
    color: var(--white);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }
  .visa-callout__heading em {
    color: rgba(196, 43, 43, 0.85);
    font-style: italic;
    text-decoration: line-through;
    text-decoration-color: rgba(196, 43, 43, 0.4);
  }

  .visa-callout__text {
    font-size: 0.95rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.75;
    max-width: 64ch;
    margin-bottom: var(--space-sm);
  }
  .visa-callout__text strong {
    color: var(--mint);
    font-weight: 500;
  }
  .visa-callout__text:last-of-type {
    margin-bottom: var(--space-md);
  }

  .visa-callout__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--mint);
    border-bottom: 1px solid rgba(127, 255, 197, 0.25);
    padding-bottom: 2px;
    transition: border-color 0.2s, color 0.2s;
  }
  .visa-callout__link:hover {
    border-color: var(--mint);
    color: var(--white);
  }

  .why__icon {
    font-family: var(--serif);
    font-size: 4rem;
    color: var(--mint);
    line-height: 1;
    margin-bottom: var(--space-md);
    font-style: italic;
  }

  .why__heading {
    font-family: var(--serif);
    font-size: 1.6rem;
    margin-bottom: var(--space-sm);
    line-height: 1.15;
  }
  .why__cell--accent .why__heading { color: var(--white); }

  .why__body {
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--muted);
    max-width: 38ch;
  }
  .why__cell--accent .why__body { color: rgba(255,255,255,0.55); }



  /* Blog grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }

  /* CTA band */
  .cta-band { background: var(--mint); padding: var(--space-lg) 0; }
  .cta-band__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-md);
  }
  .cta-band__heading {
    font-family: var(--serif);
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    color: var(--forest);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .cta-band__actions { display: flex; gap: var(--space-sm); }

  @media (max-width: 900px) {
    .why__grid { grid-template-columns: 1fr; }
    .why__grid--bottom { border-top: none; }
    .blog-grid { grid-template-columns: 1fr; }
    .cta-band__inner { grid-template-columns: 1fr; }
    .visa-callout { padding: var(--space-lg) var(--space-md); }
    .visa-callout__stamp { font-size: clamp(3rem, 15vw, 5rem); right: 0; opacity: 0.5; }
  }
</style>

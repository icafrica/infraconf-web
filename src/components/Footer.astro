---
import Logo from './Logo.astro';
import InfraConfAfricaArt from './InfraConfAfricaArt.astro';
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <!-- Why InfraConf — expanded with visa story -->
    <div class="footer__mission reveal">
      <div class="footer__mission-text">
        <span class="label label--light">Why this exists</span>
        <p>
          KubeCon, SREcon, PlatformCon — all happen in San Francisco, Amsterdam, or Chicago.
          African engineers either buy a $3,000 flight or watch a recording alone at 2am.
          InfraConf Africa is the home we needed.
        </p>
      </div>
      <div class="footer__mission-stat">
        <div style="font-family:var(--serif); font-size:3.5rem; color:var(--mint); line-height:1;">0</div>
        <div style="font-size:0.85rem; color:rgba(255,255,255,0.4); max-width:18ch; line-height:1.4;">
          Dedicated infra conferences in Africa — before us
        </div>
      </div>
    </div>

    <!-- Visa rejection callout -->
    <div class="footer__visa reveal">
      <div class="footer__visa-stamp" aria-hidden="true">REJECTED</div>
      <div class="footer__visa-body">
        <div class="footer__visa-label">The barrier nobody talks about</div>
        <h3 class="footer__visa-heading">
          The visa was <em>never</em> going to come through.
        </h3>
        <p class="footer__visa-text">
          Every year, African engineers submit Schengen applications, US B1/B2 visas, and UK visitor
          visas to attend KubeCon, AWS re:Invent, and PlatformCon. And every year, a significant
          share are rejected — not because of anything the engineer did wrong, but because the system
          doesn't believe an engineer from Lagos or Nairobi will return home from a tech conference in Chicago.
          The flight is $3,000. The hotel is $250/night. The ticket is $1,500. The visa office says no
          — with no explanation, no appeal, and no refund.
        </p>
        <p class="footer__visa-text footer__visa-text--highlight">
          <strong>InfraConf Africa is fully virtual.</strong> No passport. No visa. No embassy queue.
          No rejection letter. Just your laptop, your terminal, and a conference built for you.
        </p>
        <a href="/blog/visa-rejections-and-the-african-tech-engineer" class="footer__visa-link">
          Read: Visa rejections and the African tech engineer →
        </a>
      </div>
    </div>

    <hr class="rule-forest" style="margin-bottom:var(--space-lg);">

    <div class="footer__grid">
      <div class="footer__brand">
        <div class="footer__logo-mark">
          <Logo size={40} variant="dark" />
        </div>
        <div style="display:flex; align-items:baseline; gap:4px; margin-top:var(--space-xs); line-height:1;">
          <span style="font-family:var(--serif); font-style:italic; font-size:1.35rem; color:var(--mint); font-weight:400; letter-spacing:-0.02em;">infraconf</span>
          <span style="font-family:var(--mono); font-size:0.75rem; color:var(--white); letter-spacing:0.08em; text-transform:uppercase; font-weight:400;">africa</span>
        </div>
        <p class="footer__tagline">
          Africa's first virtual conference strictly for infrastructure engineers. November 2026.
        </p>
        <div class="footer__social">
          <a href="https://twitter.com/infraconfafrica" aria-label="Twitter/X" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L2.25 2.25h7.11l4.26 5.632 4.624-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
            </svg>
          </a>
          <a href="https://linkedin.com/company/infraconfafrica" aria-label="LinkedIn" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <div class="footer__col-head">Conference</div>
        <ul class="footer__links">
          <li><a href="/#tracks">Tracks</a></li>
          <li><a href="/#programme">Programme</a></li>
          <li><a href="https://sessionize.com/infraconf-africa-2026/" target="_blank" rel="noopener">Submit a talk</a></li>
          <li><a href="mailto:hello@infraconf.africa?subject=InfraConf Africa 2026 — Notify me">Get notified</a></li>
          <li><a href="/code-of-conduct">Code of conduct</a></li>
        </ul>
      </div>

      <div>
        <div class="footer__col-head">Sponsors</div>
        <ul class="footer__links">
          <li><a href="/#sponsors">Sponsor tiers</a></li>
          <li><a href="mailto:sponsorships@infraconf.africa">Become a founding sponsor</a></li>
        </ul>
      </div>

      <div>
        <div class="footer__col-head">Community</div>
        <ul class="footer__links">
          <li><a href="/blog">Blog</a></li>
          <li><a href="/talks">Talks</a></li>
          <li><a href="mailto:hello@infraconf.africa">Get in touch</a></li>
          <li><a href="https://icafrica.github.io/theinfra/" target="_blank" rel="noopener">theinfra ↗</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__showcase reveal">
      <InfraConfAfricaArt />
    </div>

    <div class="footer__bottom">
      <div class="footer__copy">© 2026 InfraConf Africa. All rights reserved.</div>
      <div class="footer__cncf">CNCF KCD application pending</div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--deep);
    padding: var(--space-lg) 0 var(--space-md);
    border-top: 1px solid var(--mid);
  }

  .footer__mission {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-lg);
    align-items: center;
    margin-bottom: 0;
    padding: var(--space-md);
    border: 1px solid var(--mid);
    border-bottom: none;
    background: rgba(42,92,67,0.15);
  }

  .footer__mission-text .label { display: block; margin-bottom: var(--space-xs); }

  .footer__mission-text p {
    font-size: 0.9rem;
    font-weight: 300;
    color: rgba(255,255,255,0.4);
    line-height: 1.65;
    max-width: 52ch;
  }

  /* Visa callout in footer */
  .footer__visa {
    position: relative;
    overflow: hidden;
    background: #0a1810;
    border: 1px solid var(--mid);
    border-top: none;
    padding: var(--space-lg) var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .footer__visa-stamp {
    position: absolute;
    top: 50%;
    right: -10px;
    transform: translateY(-50%) rotate(-10deg);
    font-family: var(--mono);
    font-size: clamp(3.5rem, 8vw, 7rem);
    font-weight: 700;
    letter-spacing: 0.14em;
    color: rgba(196, 43, 43, 0.06);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }

  .footer__visa-body {
    position: relative;
    z-index: 1;
    max-width: 72ch;
  }

  .footer__visa-label {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(196, 43, 43, 0.65);
    margin-bottom: var(--space-sm);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .footer__visa-label::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 1px;
    background: rgba(196, 43, 43, 0.35);
  }

  .footer__visa-heading {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: var(--white);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }
  .footer__visa-heading em {
    color: rgba(196, 43, 43, 0.8);
    font-style: italic;
    text-decoration: line-through;
    text-decoration-color: rgba(196, 43, 43, 0.35);
  }

  .footer__visa-text {
    font-size: 0.875rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.38);
    line-height: 1.75;
    max-width: 66ch;
    margin-bottom: var(--space-sm);
  }
  .footer__visa-text--highlight {
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: var(--space-md);
  }
  .footer__visa-text--highlight strong {
    color: var(--mint);
    font-weight: 500;
  }

  .footer__visa-link {
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--mint);
    border-bottom: 1px solid rgba(127, 255, 197, 0.2);
    padding-bottom: 2px;
    transition: border-color 0.2s, color 0.2s;
  }
  .footer__visa-link:hover {
    border-color: var(--mint);
    color: var(--white);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .footer__logo-mark { line-height: 1; }

  .footer__tagline {
    font-size: 0.85rem;
    font-weight: 300;
    color: rgba(255,255,255,0.35);
    line-height: 1.65;
    max-width: 26ch;
    margin-top: var(--space-sm);
  }

  .footer__social {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }
  .footer__social a {
    color: rgba(255,255,255,0.3);
    transition: color 0.2s;
  }
  .footer__social a:hover { color: var(--mint); }

  .footer__col-head {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--mint);
    margin-bottom: var(--space-sm);
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer__links a {
    font-size: 0.85rem;
    font-weight: 300;
    color: rgba(255,255,255,0.4);
    transition: color 0.2s;
  }
  .footer__links a:hover { color: var(--mint); }

  .footer__bottom {
    border-top: 1px solid var(--mid);
    padding-top: var(--space-md);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer__copy {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.04em;
  }

  .footer__cncf {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .footer__showcase {
    margin-top: var(--space-md);
    margin-bottom: var(--space-lg);
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  @media (max-width: 900px) {
    .footer__grid { grid-template-columns: 1fr 1fr; }
    .footer__mission { grid-template-columns: 1fr; }
    .footer__showcase {
      margin-top: var(--space-md);
      margin-bottom: var(--space-md);
    }
  }
  @media (max-width: 600px) {
    .footer__grid { grid-template-columns: 1fr; }
    .footer__bottom { flex-direction: column; gap: var(--space-xs); text-align: center; }
  }
</style>

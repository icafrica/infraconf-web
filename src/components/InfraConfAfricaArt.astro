    <!-- Background circuit paths for visual depth -->
    <g class="circuit-paths" opacity="0.2">
      <path class="circuit-flow" d="M 10 45 h 490 M 10 153 h 490 M 10 261 h 490" stroke="var(--mint)" stroke-width="1" />
      <path class="circuit-flow flow-delay-1" d="M 35 10 v 300 M 120 10 v 300 M 205 10 v 300 M 290 10 v 300 M 375 10 v 300 M 460 10 v 300" stroke="var(--mint)" stroke-width="0.8" />
    </g>

    <!-- ─── ROW 1: INFRA + FILLER ─── -->
    
    <!-- Letter I (Col 0) -->
    <g class="letter" id="letter-0-0">
      <rect x="25" y="0" width="20" height="90" rx="2" class="d-fill m-stroke" />
      <polygon points="35,10 42,17 35,24 28,17" class="a-fill" />

<script>
  // Add an interactive ambient pulse glow animation to random letters/fillers
  const letters = document.querySelectorAll('.infraconf-art-svg .letter');
  
  function triggerPulse() {
    if (letters.length === 0) return;
    
    // Reset previous pulse classes
    letters.forEach(el => el.classList.remove('pulse'));
    
    // Choose random letter
    const randomIndex = Math.floor(Math.random() * letters.length);
    const item = letters[randomIndex];
    
    if (item) {
      item.classList.add('pulse');
      setTimeout(() => {
        item.classList.remove('pulse');
      }, 1400);
    }
  }

  // Trigger pulse every 3.5 seconds randomly
  setInterval(triggerPulse, 3500 + Math.random() * 2000);
</script>

<style>
  .infraconf-art-wrapper {
    position: relative;
    width: 100%;
    max-width: 800px;
    margin: var(--space-md) auto;
    overflow: visible;
  }

  /* Grid pattern overlay (subtle blueprint grid) */
  .infraconf-art-bg-grid {
    position: absolute;
    inset: -20px;
    background-size: 20px 20px;
    background-image: 
      linear-gradient(to right, rgba(127, 255, 197, 0.01) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(127, 255, 197, 0.01) 1px, transparent 1px);
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }

  .infraconf-art-svg {
    width: 100%;
    height: auto;
    display: block;
    z-index: 1;
    position: relative;
  }

  /* ─── CLASS-BASED PATH STYLING ─── */
  
  /* Mint Stroke Elements */
  .m-stroke {
    stroke: rgba(127, 255, 197, 0.32);
    stroke-width: 1.5px;
    transition: stroke 0.6s cubic-bezier(0.16, 1, 0.3, 1), stroke-width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Mint Fill Elements */
  .m-fill {
    fill: rgba(127, 255, 197, 0.18);
    transition: fill 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Amber Stroke Elements */
  .a-stroke {
    stroke: rgba(232, 160, 48, 0.32);
    stroke-width: 1.5px;
    transition: stroke 0.6s cubic-bezier(0.16, 1, 0.3, 1), stroke-width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Amber Fill Elements */
  .a-fill {
    fill: rgba(232, 160, 48, 0.22);
    transition: fill 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Dark backing fills (blends into footer background #0F2B1F) */
  .d-fill {
    fill: rgba(15, 43, 31, 0.65);
    transition: fill 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Background cell card rectangles */
  .bg-card {
    fill: rgba(15, 43, 31, 0.45);
    stroke: rgba(42, 92, 67, 0.3);
    stroke-width: 1px;
    transition: fill 0.6s cubic-bezier(0.16, 1, 0.3, 1), stroke 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Circuit Flow Animations */
  .circuit-flow {
    stroke-dasharray: 15 25;
    stroke-dashoffset: 0;
    animation: flowCircuit 24s linear infinite;
  }

  .flow-delay-1 {
    animation-delay: -8s;
    animation-duration: 32s;
  }

  @keyframes flowCircuit {
    to {
      stroke-dashoffset: -100;
    }
  }

  /* Letter elements transition and hover physics */
  .letter {
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), filter 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
  }

  /* Hover State (Neon highlight) */
  .letter:hover {
    transform: scale(1.06);
    filter: drop-shadow(0 0 10px rgba(127, 255, 197, 0.65));
    z-index: 10;
  }
  .letter:hover .m-stroke {
    stroke: var(--mint);
    stroke-width: 2px;
  }
  .letter:hover .m-fill {
    fill: var(--mint);
  }
  .letter:hover .a-stroke {
    stroke: var(--amber);
    stroke-width: 2px;
  }
  .letter:hover .a-fill {
    fill: var(--amber);
  }
  .letter:hover .d-fill {
    fill: #05150f;
  }
  .letter:hover .bg-card {
    fill: rgba(15, 43, 31, 0.6);
    stroke: var(--mint);
  }

  /* Pulse State (Automatic highlight) */
  .letter.pulse {
    transform: scale(1.03);
    filter: drop-shadow(0 0 8px rgba(127, 255, 197, 0.45));
  }
  .letter.pulse .m-stroke {
    stroke: rgba(127, 255, 197, 0.7);
    stroke-width: 1.8px;
  }
  .letter.pulse .m-fill {
    fill: rgba(127, 255, 197, 0.6);
  }
  .letter.pulse .a-stroke {
    stroke: rgba(232, 160, 48, 0.7);
    stroke-width: 1.8px;
  }
  .letter.pulse .a-fill {
    fill: rgba(232, 160, 48, 0.6);
  }
  .letter.pulse .d-fill {
    fill: #071c13;
  }
  .letter.pulse .bg-card {
    fill: rgba(15, 43, 31, 0.4);
    stroke: rgba(127, 255, 197, 0.5);
  }

  /* Center points for transform scaling */
  #letter-0-0 { transform-origin: 35px 45px; }
  #letter-1-0 { transform-origin: 120px 45px; }
  #letter-2-0 { transform-origin: 205px 45px; }
  #letter-3-0 { transform-origin: 290px 45px; }
  #letter-4-0 { transform-origin: 375px 45px; }
  #letter-5-0 { transform-origin: 460px 45px; }

  #letter-0-1 { transform-origin: 35px 153px; }
  #letter-1-1 { transform-origin: 120px 153px; }
  #letter-2-1 { transform-origin: 205px 153px; }
  #letter-3-1 { transform-origin: 290px 153px; }
  #letter-4-1 { transform-origin: 375px 153px; }
  #letter-5-1 { transform-origin: 460px 153px; }

  #letter-0-2 { transform-origin: 35px 261px; }
  #letter-1-2 { transform-origin: 120px 261px; }
  #letter-2-2 { transform-origin: 205px 261px; }
  #letter-3-2 { transform-origin: 290px 261px; }
  #letter-4-2 { transform-origin: 375px 261px; }
  #letter-5-2 { transform-origin: 460px 261px; }
</style>

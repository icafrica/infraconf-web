---
const tiers = [
  {
    badge: 'Community sponsor',
    price: '$750',
    period: 'Per event',
    featured: false,
    benefits: [
      'Logo on website, event page & stream overlays',
      'Social mention at announcement & post-event',
      'Job listing on conference board — 3 months',
      'Named in opening keynote acknowledgements',
      '2 complimentary virtual passes',
    ],
  },
  {
    badge: 'Founding sponsor',
    price: '$2,500',
    period: 'Per event',
    featured: true,
    benefits: [
      'Prominent logo on all materials & stream overlays',
      '5-min lightning talk slot during main programme',
      'Job listings on conference board — 6 months',
      'Founding Partner badge — permanent recognition',
      'Mentioned in opening & closing keynotes',
      'Full attendee list post-event (opt-in)',
      'Priority right for 2027 physical conference',
      '2 complimentary workshop passes',
    ],
  },
  {
    badge: 'Tool sponsor',
    price: 'In-kind',
    period: 'Tool licenses / credits',
    featured: false,
    benefits: [
      'Free tool licenses / credits donated to attendees',
      'Logo on website & \'tools we love\' section',
      'Social mention post with tool description',
      'Community goodwill — engineers become advocates',
      '1 complimentary virtual pass',
    ],
  },
];
---

<section class="section" id="sponsors" aria-labelledby="sponsors-heading">
  <div class="container">
    <div class="section__header">
      <span class="label">05 — Sponsors</span>
      <hr>
      <h2 class="label" id="sponsors-heading" style="color:var(--muted)">Community investment, not advertising</h2>
    </div>

    <div class="tiers reveal">
      {tiers.map(({ badge, price, period, featured, benefits }) => (
        <div class={`tier${featured ? ' tier--featured' : ''}`}>
          <div class="tier__badge">{badge}</div>
          <div class="tier__price">{price}</div>
          <div class="tier__name">{period}</div>
          <div class="tier__divider"></div>
          <ul class="tier__benefits">
            {benefits.map(b => <li class="tier__benefit">{b}</li>)}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-md reveal reveal-delay-2" style="text-align:center;">
      <a href="mailto:sponsorships@infraconf.africa" class="btn btn--primary">
        Become a founding partner
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <p style="font-size:0.8rem; color:var(--muted); margin-top:10px; font-family:var(--mono);">
        sponsorships@infraconf.africa · Founding spots are limited
      </p>
    </div>
  </div>
</section>

<style>
  .tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }

  .tier { background: var(--white); padding: var(--space-md); }
  .tier--featured { background: var(--forest); }

  .tier__badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid var(--rule);
    padding: 4px 10px;
    border-radius: 1px;
    color: var(--muted);
    margin-bottom: var(--space-md);
  }
  .tier--featured .tier__badge { border-color: rgba(127,255,197,0.3); color: var(--mint); }

  .tier__price {
    font-family: var(--serif);
    font-size: 2.5rem;
    line-height: 1;
    color: var(--forest);
    margin-bottom: var(--space-xs);
  }
  .tier--featured .tier__price { color: var(--mint); }

  .tier__name { font-size: 0.85rem; font-weight: 300; color: var(--muted); margin-bottom: var(--space-md); }
  .tier--featured .tier__name { color: rgba(255,255,255,0.45); }

  .tier__divider { height: 1px; background: var(--rule); margin-bottom: var(--space-md); }
  .tier--featured .tier__divider { background: var(--mid); }

  .tier__benefits { display: flex; flex-direction: column; gap: 10px; }

  .tier__benefit {
    display: grid;
    grid-template-columns: 16px 1fr;
    gap: 10px;
    font-size: 0.85rem;
    color: var(--forest);
    font-weight: 300;
    line-height: 1.45;
  }
  .tier--featured .tier__benefit { color: rgba(255,255,255,0.7); }
  .tier__benefit::before {
    content: '—';
    font-family: var(--mono);
    color: var(--mint);
    font-size: 0.7rem;
    padding-top: 2px;
  }

  @media (max-width: 900px) { .tiers { grid-template-columns: 1fr; } }
</style>

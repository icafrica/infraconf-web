---
const tiers = [
  {
    badge: 'Community Partner',
    label: 'Visibility & reach',
    tagline: 'Put your brand in front of Africa\'s infrastructure engineers.',
    featured: false,
    benefits: [
      'Logo on website, event page & stream overlays',
      'Social mention at announcement & post-event wrap-up',
      'Job listing on conference board for 3 months',
      'Named in opening keynote acknowledgements',
      '2 complimentary virtual passes for your team',
    ],
  },
  {
    badge: 'Anchor Partner',
    label: 'Deep integration',
    tagline: 'Be woven into the fabric of InfraConf Africa — on stage and online.',
    featured: true,
    benefits: [
      'Prominent logo placement across all event materials & overlays',
      '5-min lightning talk slot during the main programme',
      'Job listings on conference board for 6 months',
      'Recognised in both opening & closing keynotes',
      'Post-event attendee insights report (opt-in data)',
      'First-look opportunity for 2027 in-person conference',
      '2 complimentary workshop passes for your engineers',
    ],
  },
  {
    badge: 'Tool Partner',
    label: 'In-kind support',
    tagline: 'Donate licenses or credits — engineers who use your tool become its best advocates.',
    featured: false,
    benefits: [
      'Tool licenses or platform credits gifted directly to attendees',
      'Logo on website & featured in our "Tools We Love" spotlight',
      'Dedicated social post introducing your tool to the community',
      'Authentic grassroots advocacy from practitioners',
      '1 complimentary virtual pass for your team',
    ],
  },
];
---

<section class="section" id="sponsors" aria-labelledby="sponsors-heading">
  <div class="container">
    <div class="section__header">
      <span class="label">05 — Partners</span>
      <hr>
      <h2 class="label" id="sponsors-heading" style="color:var(--muted)">Community investment, not advertising</h2>
    </div>

    <div class="sponsor-intro reveal">
      <p class="sponsor-intro__text">
        InfraConf Africa is free for every attendee. That only works because companies that care about
        the African infrastructure community choose to back it. If that sounds like your organisation,
        we'd love to talk — reach out and we'll send you our full partnership prospectus.
      </p>
    </div>

    <div class="tiers reveal">
      {tiers.map(({ badge, label, tagline, featured, benefits }) => (
        <div class={`tier${featured ? ' tier--featured' : ''}`}>
          <div class="tier__badge">{badge}</div>
          <div class="tier__label">{label}</div>
          <p class="tier__tagline">{tagline}</p>
          <div class="tier__divider"></div>
          <ul class="tier__benefits">
            {benefits.map(b => <li class="tier__benefit">{b}</li>)}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-md reveal reveal-delay-2" style="text-align:center;">
      <div class="sponsor-cta-btns">
        <a href="mailto:sponsorships@infraconf.africa?subject=Partnership%20Enquiry%20%E2%80%94%20InfraConf%20Africa%202026" class="btn btn--primary">
          Request the partnership prospectus
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.5"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="https://cal.com/infraconf-africa-socsh9/15min" class="btn btn--ghost" target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Book a 15-min call
        </a>
      </div>
      <p style="font-size:0.8rem; color:var(--muted); margin-top:10px; font-family:var(--mono);">
        sponsorships@infraconf.africa · Anchor Partner spots are limited
      </p>
    </div>
  </div>
</section>

<style>
  .sponsor-cta-btns {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .sponsor-intro {
    max-width: 72ch;
    margin: 0 auto var(--space-lg);
    text-align: center;
  }
  .sponsor-intro__text {
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.8;
  }

  .tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }

  .tier { background: var(--white); padding: var(--space-md); }
  .tier--featured { background: var(--forest); }

  .tier__badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid var(--rule);
    padding: 4px 10px;
    border-radius: 1px;
    color: var(--muted);
    margin-bottom: var(--space-sm);
  }
  .tier--featured .tier__badge { border-color: rgba(127,255,197,0.3); color: var(--mint); }

  .tier__label {
    font-family: var(--serif);
    font-size: 1.6rem;
    line-height: 1.1;
    color: var(--forest);
    margin-bottom: var(--space-xs);
    letter-spacing: -0.02em;
  }
  .tier--featured .tier__label { color: var(--mint); }

  .tier__tagline {
    font-size: 0.82rem;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: var(--space-md);
    max-width: 32ch;
  }
  .tier--featured .tier__tagline { color: rgba(255,255,255,0.45); }

  .tier__divider { height: 1px; background: var(--rule); margin-bottom: var(--space-md); }
  .tier--featured .tier__divider { background: rgba(255,255,255,0.12); }

  .tier__benefits { display: flex; flex-direction: column; gap: 10px; }

  .tier__benefit {
    display: grid;
    grid-template-columns: 16px 1fr;
    gap: 10px;
    font-size: 0.85rem;
    color: var(--forest);
    font-weight: 300;
    line-height: 1.45;
  }
  .tier--featured .tier__benefit { color: rgba(255,255,255,0.7); }
  .tier__benefit::before {
    content: '—';
    font-family: var(--mono);
    color: var(--mint);
    font-size: 0.7rem;
    padding-top: 2px;
  }

  @media (max-width: 900px) { .tiers { grid-template-columns: 1fr; } }
</style>

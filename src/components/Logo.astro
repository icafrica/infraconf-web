---
/**
 * InfraConf Africa — Minimal Monogram Logo Mark
 *
 * A creative, minimal typographic monogram of "ic" (InfraConf) where:
 *   - "i" is a vertical stem on the left, with a glowing mint green dot (status LED).
 *   - "c" is a geometric curve on the right.
 *
 * Props:
 *   size     — pixel size for width/height (default 32)
 *   variant  — "dark" (on forest/deep bg) | "light" (on cream bg) | "mono"
 */
interface Props {
  size?: number;
  variant?: 'dark' | 'light' | 'mono';
  class?: string;
}

const { size = 32, variant = 'dark', class: className = '' } = Astro.props;

const colors = {
  dark: {
    stem: '#FFFFFF',
    dot: '#7FFFC5',
  },
  light: {
    stem: '#0F2B1F',
    dot: '#1D4C37',
  },
  mono: {
    stem: 'currentColor',
    dot: 'currentColor',
  },
}[variant];
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  role="img"
>
  <!-- Lowercase "i" stem -->
  <line
    x1="14"
    y1="20"
    x2="14"
    y2="34"
    stroke={colors.stem}
    stroke-width="3.5"
    stroke-linecap="round"
  />

  <!-- Lowercase "i" dot (glowing LED) -->
  <circle
    cx="14"
    cy="12"
    r="2.5"
    fill={colors.dot}
  />

  <!-- Lowercase "c" curve -->
  <path
    d="M 34 20 Q 22 20 22 27 Q 22 34 34 34"
    stroke={colors.stem}
    stroke-width="3.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    fill="none"
  />
</svg>
